# ============================================================
# Aloha Health Hub — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# Supabase — Frontend (safe to expose to the browser)
# Get these from: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------
# Supabase — Service Role (BACKEND / SCRIPTS ONLY)
# ⚠️  NEVER prefix with VITE_ — this must NEVER reach the browser.
# Used only by local Node.js scripts in scripts/ (ingestion, etc.)
# Get from: Supabase Dashboard → Project Settings → API → service_role key
# ------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Optional: Geocoding (Sprint 4+)
# Only needed if you enable address → lat/lng geocoding in scripts
# ------------------------------------------------------------
# GOOGLE_GEOCODING_API_KEY=your-google-api-key-here

# --- Ingestion scripts only (scripts/ingest.mjs) ---
# Can reuse the same project URL as VITE_SUPABASE_URL above, but without the VITE_ prefix
# SUPABASE_URL=https://your-project-ref.supabase.co

# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Maps Places API
GM_API_KEY=your_google_maps_api_key

# Brave Search (pipeline)
BRAVE_API_KEY=your_brave_api_key

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...   # publishable key (safe to expose in browser)
STRIPE_SECRET_KEY=sk_live_...             # secret key — server/edge function only, never in browser
STRIPE_WEBHOOK_SECRET=whsec_...          # from Stripe dashboard → Webhooks → signing secret

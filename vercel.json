{
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/profile/:id",
      "destination": "/api/profile/[id]"
    },
    {
      "source": "/api/center/:id",
      "destination": "/api/center/[id]"
    },
    {
      "source": "/api/offering/:id",
      "destination": "/api/offering/[id]"
    },
    {
      "source": "/api/sitemap-practitioners.xml",
      "destination": "/api/sitemap-practitioners.xml"
    },
    {
      "source": "/api/sitemap-centers.xml",
      "destination": "/api/sitemap-centers.xml"
    },
    {
      "source": "/api/sitemap-articles.xml",
      "destination": "/api/sitemap-articles.xml"
    },
    { "source": "/api/articles/:slug", "destination": "/api/articles/[slug]" },
    { "source": "/api/island/:island", "destination": "/api/island/[island]" }
  ],
  "headers": [
    {
      "source": "/auth(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/dashboard(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/admin(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/claim/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/testimonial/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "geolocation=(self), camera=(), microphone=()" },
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://images.unsplash.com https://*.basemaps.cartocdn.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://*.basemaps.cartocdn.com; frame-src https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'"
        }
      ]
    }
  ]
}
